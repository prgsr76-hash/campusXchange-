PORT=5000
JWT_SECRET=campusxchange_secret_key_123

# MongoDB Atlas Configuration URI
# (If empty or commented out, the server runs in local JSON fallback mode)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/campusxchange?retryWrites=true&w=majority

# Cloudinary Image API Keys
# (If empty or commented out, images are saved locally to public/uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
